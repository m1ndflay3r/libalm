## bitmask
albm() {
  local bm_num="$1" mask="$2" outvar=${3:-al_return} cmp
  local -i is_neg
  [[ -z "$bm_num" || -z "$mask" ]] && return 1
  [[ ${mask::1} = '-' ]] && {
    ((is_neg++))
    mask=${mask:1}
    [[ ${bm_num::1} != '-' ]] && {
      bm_num="-"$bm_num""
    } || {
      bm_num=${bm_num:1}
    }
  }
  ! [[ -z "$hexmask" ]] && hex2dec "$mask" mask
  alcm "$bm_num" "$mask"; cmp=$?
  ((cmp==3)) && {
    ((is_neg)) && [[ "$bm_num" != '0' ]] && bm_num="-"$bm_num""
    eval "$outvar=\"\$bm_num\""
    return 0
  }
  alia "$mask" 1 mask
  [[ ${bm_num::1} = '-' ]] && {
    until [[ ${bm_num::1} != '-' ]]; do
      alia "$mask" "$bm_num" bm_num
    done
    ((is_neg)) && [[ "$bm_num" != '0' ]] && bm_num="-"$bm_num""
    eval "$outvar=\"\$bm_num\""
    return 0
  } || {
    almo "$bm_num" "$mask" bm_num
    ((is_neg)) && [[ "$bm_num" != '0' ]] && bm_num="-"$bm_num""
    eval "$outvar=\"\$bm_num\""
    return 0
  }
}

## rotate right
rrot() {
  local rrot_w="$1" rot_c=${2:-1} outvar=${3:-al_return}
  local -i t rot_ln
  [[ -z "$rrot_w" ]] && return 1
  dat2bin "$rrot_w" rrot_w
  rot_ln=$((${#rrot_w}-1))
  for ((t=0; t<rot_c; t++)); do
    rrot_w=""${rrot_w:$rot_ln}""${rrot_w::$rot_ln}""
  done
  bin2dat "$rrot_w" rrot_w
  eval "$outvar=\"\$rrot_w\""
}

