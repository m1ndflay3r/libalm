#!/usr/bin/env zsh

## arbitrarily large integer adder
alia() {
  # take input as strings
  local num1="$1" num2="$2" working out
  local -i num_ln neg1 neg2 is_sub sign w c
  ([ -z "$num1" ] || [ -z "$num2" ]) && return 1
  # if num is neg, set flag and strip '-'
  [ ${num1::1} = '-' ] && {
    ((neg1++))
    num1=${num1:1}
  }
  [ ${num2::1} = '-' ] && {
    ((neg2++))
    num2=${num2:1}
  }
  # if one number is negative but the other isnt, treat as subtraction
  ((neg1!=neg2)) && {
    ((is_sub++))
  }
  # zero-pad shorter num
  ((${#num1}>=${#num2})) && {
    num_ln=${#num1}
    num2="${(l:num_ln::0:)num2}"
  } || {
    num_ln=${#num2}
    num1="${(l:num_ln::0:)num1}"
  }
  # if is sub, we take sign of larger num
  ((is_sub)) && {
    [[ "$num1" > "$num2" ]] && {
      ((neg1)) && ((sign++))
    }
    [[ "$num2" > "$num1" ]] && {
      ((neg2)) && ((sign++))
    }
  }
  # if both are neg, output is neg
  (((neg1)) && ((neg2))) && ((sign++))
  # begin iteration over nums
  for ((i=num_ln; i>0; i--)); do
    ((is_sub)) && {
      [[ "$num1" > "$num2" ]] && {
        w=$((num1[$i]-num2[$i]))
      } || {
        w=$((num2[$i]-num1[$i]))
      }
    } || {
      w=$((num1[$i]+num2[$i]))
      ((c)) && {
        ((w++))
        ((c--))
      }
      ((w>=10)) && {
        ((c++))
        w=${w:1}
      }
    }
    out=""$w""$out""
  done
  ((c)) && out="1"$out""
  ((sign)) && out="-"$out""
  print -r "$out"
}
