## bitmask
albm() {
  local bm_num="$1" mask="$2" outvar=${3:-al_return} cmp
  local -i is_neg
  [[ -z "$bm_num" || -z "$mask" ]] && return 1
  # if mask is negative, set neg flag, strip '-' from mask, and invert pos/neg state of bm_num
  [[ ${mask::1} = '-' ]] && {
    ((is_neg++))
    mask=${mask:1}
    [[ ${bm_num::1} != '-' ]] && {
      bm_num="-"$bm_num""
    } || {
      bm_num=${bm_num:1}
    }
  }
  # if variable 'hexmask' is set, expect $mask to contain a hex value and conv to decimal
  ! [[ -z "$hexmask" ]] && hex2dec "$mask" mask
  # if num=mask, no math is needed
  alcm "$bm_num" "$mask"; cmp=$?
  ((cmp==3)) && {
    ((is_neg)) && [[ "$bm_num" != '0' ]] && bm_num="-"$bm_num""
    eval "$outvar=\"\$bm_num\""
    return 0
  }
  # increase mask by 1 since we're using modulo
  alia "$mask" 1 mask
  # negative num handler
  [[ ${bm_num::1} = '-' ]] && {
    bm_num=${bm_num:1}
    almo "$bm_num" "$mask" bm_num
    [[ "$bm_num" != '0' ]] && alis "$mask" "$bm_num" bm_num
    ((is_neg)) && [[ "$bm_num" != '0' ]] && bm_num="-"$bm_num""
    eval "$outvar=\"\$bm_num\""
    return 0
  # positive num handler
  } || {
    almo "$bm_num" "$mask" bm_num
    ((is_neg)) && [[ "$bm_num" != '0' ]] && bm_num="-"$bm_num""
    eval "$outvar=\"\$bm_num\""
    return 0
  }
}

## rotate right
rrot() {
  local rrot_w="$1" rot_c=${2:-1} outvar=${3:-al_return}
  local -i t rot_ln
  [[ -z "$rrot_w" ]] && return 1
  dat2bin "$rrot_w" rrot_w
  rot_ln=$((${#rrot_w}-1))
  for ((t=0; t<rot_c; t++)); do
    rrot_w=""${rrot_w:$rot_ln}""${rrot_w::$rot_ln}""
  done
  bin2dat "$rrot_w" rrot_w
  eval "$outvar=\"\$rrot_w\""
}

## rotate left
lrot() {
  local lrot_w="$1" rot_c=${2:-1} outvar=${3:-al_return}
  local -i u
  [[ -z "$lrot_w" ]] && return 1
  dat2bin "$lrot_w" lrot_w
  for ((u=0; u<rot_c; u++)); do
    lrot_w=""${lrot_w:1}""${lrot_w::1}""
  done
  bin2dat "$lrot_w" lrot_w
  eval "$outvar=\"\$lrot_w\""
}

## shift right
rshft() {
  local rshft_w="$1" shft_c=${2:-1} outvar=${3:-al_return}
  local -i v shft_ln
  [[ -z "$rshft_w" ]] && return 1
  dat2bin "$rshft_w" rshft_w
  shft_ln=$((${#rshft_w}-1))
  for ((v=0; v<shft_c; v++)); do
    rshft_w="0"${rshft_w::$shft_ln}""
  done
  bin2dat "$rshft_w" rshft_w
  eval "$outvar=\"\$rshft_w\""
}

## shift left
lshft() {
  local lshft_w="$1" shft_c=${2:-1} outvar=${3:-al_return}
  local -i x
  [[ -z "$lshft_w" ]] && return 1
  dat2bin "$lshft_w" lshft_w
  for ((x=0; x<shft_c; x++)); do
    lshft_w=""${lshft_w:1}"0"
  done
  bin2dat "$lshft_w" lshft_w
  eval "$outvar=\"\$lshft_w\""
}

## bitwise XOR
alxor() {
  local num1="$1" num2="$2" outvar=${3:-al_return} out="" c1 c2 w
  local -i y pad_ln rem orig_ln
  [[ -z "$num1" || -z "$num2" ]] && return 1
  # conv to binary
  dat2bin "$num1" num1
  dat2bin "$num2" num2
  # 0-pad to maxln if needed
  ((${#num1}>${#num2})) && num2="${(l:${#num1}::0:)num2}"
  ((${#num2}>${#num1})) && num1="${(l:${#num2}::0:)num1}"
  orig_ln=${#num1}
  # 0-pad both nums to a multiple of 60
  rem=$((orig_ln%60))
  ((rem)) && {
    pad_ln=$((orig_ln+60 - rem))
    num1="${(l:pad_ln::0:)num1}"
    num2="${(l:pad_ln::0:)num2}"
  } || pad_ln=$orig_ln
  # loop through bits in 60-bit chunks
  for ((y=0; y<pad_ln; y+=60)); do
    c1=${num1:$y:60}
    c2=${num2:$y:60}
    # do native 60-bit XOR; conv back to bin
    w=$(([##2]2#$c1 ^ 2#$c2))
    # 0-pad to 60 chars; append
    w="${(l:60::0:)w}"
    out+="$w"
  done
  # remove 0-pad to restore original data ln
  ((rem)) && out=${out:$((60-rem))}
  bin2dat "$out" "$outvar"
}

