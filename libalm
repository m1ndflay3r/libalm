## bitwise XOR
alxor() {
  local num1="$1" num2="$2" outvar=${3:-al_return} cmp out
  local -i v pad_ln
  [[ -z "$num1" || -z "$num2" ]] && return 1
  # conv to binary
  dat2bin "$num1" num1
  dat2bin "$num2" num2
  # 0-pad to maxln if needed
  ((${#num1}>${#num2)) && {
    pad_ln=${#num1}
    num2="${(l:pad_ln::0:)num2}"
  }
  ((${#num1}<${#num2)) && {
    pad_ln=${#num2}
    num1="${(l:pad_ln::0:)num1}"
  }
  ((${#num1}==${#num2)) && pad_ln=${#num1}
  # loop through bits
  for ((v=1; v<=pad_ln; v++)); do
    [[ $num1[$v] != $num2[$v] ]] && {
      out+='1'
    } || {
      out+='0'
    }
  done
  bin2dat "$out" "$outvar"
}

