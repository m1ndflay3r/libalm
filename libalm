#!/usr/bin/env zsh

## arbitrarily large comparator
alcm() {
  local num1="$1" num2="$2" n1_macro n1_micro n2_macro n2_micro w1 w2 micro_ln num_ln
  local -i neg1 neg2
  # since we use return for result, use 0 to indicate invalid
  [[ -z "$num1" || -z "$num2" ]] && return 0
  # ensure nums are valid float
  [[ "$num1" != *'.'* ]] && num1=""$num1".0"
  [[ "$num2" != *'.'* ]] && num2=""$num2".0"
  # -0 and 0 are the same, so lets not confuse anything
  [[ "$num1" = '-0.0' ]] && num1='0.0'
  [[ "$num2" = '-0.0' ]] && num2='0.0'
  # handle negatives
  [[ ${num1::1} = '-' ]] && {
    ((neg1++))
    num1=${num1:1}
  }
  [[ ${num2::1} = '-' ]] && {
    ((neg2++))
    num2=${num2:1}
  }
  # if one num is neg but the other isnt we have our answer
  (((neg1)) && ! ((neg2))) && return 2
  (((neg2)) && ! ((neg1))) && return 1
  # strip leading zeros
  [[ ${num1::1} = 0 ]] && {
    until [[ ${num1::1} != '0' ]]; do
      num1=${num1:1}
    done
  }
  [[ ${num2::1} = 0 ]] && {
    until [[ ${num2::1} != '0' ]]; do
      num2=${num2:1}
    done
  }
  # adjust in case num was below zero decimal
  [[ ${num1::1} = '.' ]] && num1="0"$num1""
  [[ ${num2::1} = '.' ]] && num2="0"$num2""
  # separate int from decimal
  n1_macro=${num1%%.*}
  n1_micro=${num1#*.}
  n2_macro=${num2%%.*}
  n2_micro=${num2#*.}
  # right pad decimals with 0s until same length
  ((${#n1_micro}>=${#n2_micro})) && {
    micro_ln=${#n1_micro}
    n2_micro="${(r:micro_ln::0:)n2_micro}"
  } || {
    micro_ln=${#n2_micro}
    n1_micro="${(r:micro_ln::0:)n1_micro}"
  }
  # reconstruct num1 and num2 as integers
  num1=""$n1_macro""$n1_micro""
  num2=""$n2_macro""$n2_micro""
  # neg comparator
  ((neg1)) && {
    ((${#num1}>${#num2})) && return 2
    ((${#num1}<${#num2})) && return 1
    [[ "$num1" > "$num2" ]] && return 2
    [[ "$num1" < "$num2" ]] && return 1
  # pos comparator
  } || {
    ((${#num1}>${#num2})) && return 1
    ((${#num1}<${#num2})) && return 2
    [[ "$num1" > "$num2" ]] && return 1
    [[ "$num1" < "$num2" ]] && return 2
  }
  # if we've reached here, nums must be the same
  return 3
}

## arbitrarily large integer adder
alia() {
  # take input as strings
  local num1="$1" num2="$2" working out temp
  local -i num_ln neg1 neg2 is_sub sign w c b
  [[ -z "$num1" || -z "$num2" ]] && return 1
  # treat 0 and -0 the same
  [[ "$num1" = '-0' ]] && num1=0
  [[ "$num2" = '-0' ]] && num2=0
  # if one num is 0, answer is other num
  [[ "$num1" = '0' ]] && {
    print -r "$num2"
    return 0
  }
  [[ "$num2" = '0' ]] && {
    print -r "$num1"
    return 0
  }
  # if num is neg, set flag and strip '-'
  [[ ${num1::1} = '-' ]] && {
    ((neg1++))
    num1=${num1:1}
  }
  [[ ${num2::1} = '-' ]] && {
    ((neg2++))
    num2=${num2:1}
  }
  # if one number is negative but the other isnt, treat as subtraction
  ((neg1!=neg2)) && {
    ((is_sub++))
  }
  # zero-pad shorter num
  ((${#num1}>=${#num2})) && {
    num_ln=${#num1}
    num2="${(l:num_ln::0:)num2}"
  } || {
    num_ln=${#num2}
    num1="${(l:num_ln::0:)num1}"
  }
  # if is sub, we take sign of larger num
  ((is_sub)) && {
    [[ "$num1" > "$num2" ]] && {
      ((neg1)) && ((sign++))
    }
    [[ "$num2" > "$num1" ]] && {
      ((neg2)) && ((sign++))
      temp="$num1"
      num1="$num2"
      num2="$temp"
    }
  }
  # if both are neg, output is neg
  (((neg1)) && ((neg2))) && ((sign++))
  # begin iteration over nums
  for ((i=num_ln; i>0; i--)); do
    ((is_sub)) && {
      w=$((num1[$i]-num2[$i]))
      ((b)) && {
        ((w--))
        ((b--))
      }
      ((w<0)) && {
        ((b++))
        ((w+=10))
      }
      true
    } || {
      w=$((num1[$i]+num2[$i]))
      ((c)) && {
        ((w++))
        ((c--))
      }
      ((w>=10)) && {
        ((c++))
        w=${w:1}
      }
    }
    out=""$w""$out""
  done
  # add last carry if needed
  (((c)) && [[ -z "$ret_carry" ]]) && out="1"$out""
  # strip unneeded zeros
  [[ ${out::1} = 0 ]] && {
    until [[ ${out::1} != '0' ]]; do
      ((${#out}==1)) && break
      out=${out:1}
    done
  }
  # add neg sign if needed
  ((sign)) && out="-"$out""
  # print result
  print -r "$out"
  # if ret_carry is set, return $c/$b (for alfa); else return 0
  ! [[ -z "$ret_carry" ]] && {
    ((is_sub)) && {
      return $((b+2))
    } || {
      return $c
    }
  } || {
    return 0
  }
}

## arbitrarily large integer subtractor
alis() {
  local num1="$1" num2="$2"
  [[ -z "$num1" || -z "$num2" ]] && return 1
  # invert sign of 2nd num
  [[ ${num2::1} = '-' ]] && {
    num2=${num2:1}
  } || {
    num2="-"$num2""
  }
  # feed to alia
  alia "$num1" "$num2"
}

## arbitrarily large float adder
alfa() {
  local num1="$1" num2="$2" num1_macro num1_micro num2_macro num2_micro macro micro out w10=1
  local -i micro_ln carry_val pad_ln
  [[ -z "$num1" || -z "$num2" ]] && return 1
  [[ "$num1" != *"."* ]] && num1=""$num1".0"
  [[ "$num2" != *"."* ]] && num2=""$num2".0"
  # treat 0.0 and -0.0 the same
  [[ "$num1" = '-0.0' ]] && num1=0.0
  [[ "$num2" = '-0.0' ]] && num2=0.0
  # if one num is 0.0, answer is other num
  [[ "$num1" = '0.0' ]] && {
    print -r "$num2"
    return 0
  }
  [[ "$num2" = '0.0' ]] && {
    print -r "$num1"
    return 0
  }
  # separate n1 and n2 into micro+macro
  num1_macro=${num1%%.*}
  num1_micro=${num1#*.}
  num2_macro=${num2%%.*}
  num2_micro=${num2#*.}
  # right-pad micros with 0s to ln of largest
  ((${#num1_micro}>=${#num2_micro})) && {
    micro_ln=${#num1_micro}
    num2_micro="${(r:micro_ln::0:)num2_micro}"
  } || {
    micro_ln=${#num2_micro}
    num1_micro="${(r:micro_ln::0:)num1_micro}"
  }
  # micros should have same sign as macros
  [[ ${num1_macro::1} = '-' ]] && num1_micro="-"$num1_micro""
  [[ ${num2_macro::1} = '-' ]] && num2_micro="-"$num2_micro""
  # add macro
  macro=$(alia "$num1_macro" "$num2_macro")
  # add micro, handle carry
  micro=$(ret_carry=1 alia "$num1_micro" "$num2_micro")
  carry_val=$?
  ((carry_val==1)) && {
    [[ ${macro::1} = '-' ]] && {
      macro=${macro:1}
      macro=$(alia "$macro" 1)
      macro="-"$macro""
    } || {
      macro=$(alia "$macro" 1)
    }
  }
  ((carry_val==3)) && {
    [[ ${macro::1} = '-' ]] && {
      macro=${macro:1}
      macro=$(alia "$macro" -1)
      macro="-"$macro""
    } || {
      macro=$(alia "$macro" -1)
    }
  }
  # handle fractional borrowing
  [[ ( ${macro::1} = '-' && ${micro::1} != '-' ) || ( ${micro::1} = '-' && ${macro::1} != '-' ) ]] && {
    [[ ${macro::1} = '-' ]] && {
      macro=${macro:1}
      macro=$(alia "$macro" -1)
      macro="-"$macro""
    } || {
      macro=$(alia "$macro" -1)
    }
    micro_ln=${#micro}
    pad_ln=$((micro_ln+1))
    w10="${(r:pad_ln::0:)w10}"
    [[ ${micro::1} = '-' ]] && {
      micro=$(alia "$w10" "$micro")
    } || {
      micro="-"$micro""
      micro=$(alia "$w10" "$micro")
    }
  }
  [[ ${micro::1} = '-' ]] && micro=${micro:1}
  # reassemble output
  out=""$macro"."$micro""
  [[ "$out" = "-0.0" ]] && out="0.0"
  print -r "$out"
}

## arbitrarily large float subtractor
alfs() {
  local num1="$1" num2="$2"
  [[ -z "$num1" || -z "$num2" ]] && return 1
  # invert sign of 2nd num
  [[ ${num2::1} = '-' ]] && {
    num2=${num2:1}
  } || {
    num2="-"$num2""
  }
  # feed to alfa
  alfa "$num1" "$num2"
}

## arbitrarily large integer multiplier
alim() {
  local num1="$1" num2="$2" out='0' w1 w2 w carry='0' row=''
  local -i neg1 neg2 is_neg shft carryln row_ln
  [[ -z "$num1" || -z "$num2" ]] && return 1
  # handle multiply by zero
  [[ "$num1" = "0" || "$num2" = "0" || "$num1" = "-0" || "$num2" = "-0" ]] && {
    print -r "0"
    return 0
  }
  # trim negs
  [[ ${num1::1} = '-' ]] && {
    num1=${num1:1}
    ((neg1++))
  }
  [[ ${num2::1} = '-' ]] && {
    num2=${num2:1}
    ((neg2++))
  }
  # handle negs
  ((neg1!=neg2)) && {
    ((is_neg++))
  }
  # outer loop - read num2 from r to l
  for ((i=${#num2}; i>0; i--)); do
    w2=$num2[$i]
    row=''
    carry='0'
    # inner loop - read num1 from r to l
    for ((j=${#num1}; j>0; j--)); do
      w1=$num1[$j]
      w=$(((w1*w2)+carry))
      ((${#w}==1)) && carry='0'
      ((${#w}>1)) && {
        carryln=$((${#w}-1))
        carry=${w::$carryln}
        w=${w:$carryln}
      }
      row=""$w""$row""
    done
    ((carry>0)) && row=""$carry""$row""
    # zero pad row equal to current shft
    row_ln=$((${#row}+$shft))
    row="${(r:row_ln::0:)row}"
    # add to total
    out=$(alia "$out" "$row")
    ((shft++))
  done
  # handle neg sign
  ((is_neg)) && out="-"$out""
  print -r "$out"
}

## arbitrarily large float multiplier
alfm() {
  local num1="$1" num2="$2" n1_micro n2_micro macro micro w out
  local -i neg1 neg2 is_neg deci_ln pad_ln
  [[ -z "$num1" || -z "$num2" ]] && return 1
  # ensure is valid float
  [[ "$num1" != *"."* ]] && num1=""$num1".0"
  [[ "$num2" != *"."* ]] && num2=""$num2".0"
  # fast exit on 0
  [[ "$num1" = '0.0' || "$num1" = '-0.0' || "$num2" = '0.0' || "$num2" = '-0.0' ]] && {
    print -r '0.0'
    return 0
  }
  # handle negs
  [[ ${num1::1} = '-' ]] && {
    num1=${num1:1}
    ((neg1++))
  }
  [[ ${num2::1} = '-' ]] && {
    num2=${num2:1}
    ((neg2++))
  }
  # if one num neg but other not, result is neg
  ((neg1!=neg2)) && {
    ((is_neg++))
  }
  # separate decimals from integers
  n1_micro=${num1#*.}
  n2_micro=${num2#*.}
  # get decimal ln
  deci_ln=$((${#n1_micro}+${#n2_micro}))
  # conv num1 and num2 to integers
  num1=${num1//'.'/''}
  num2=${num2//'.'/''}
  # multiply using alim
  w=$(alim "$num1" "$num2")
  # left-pad w with 0s if less than pad ln
  pad_ln=$((deci_ln+1))
  ((${#w}<pad_ln)) && {
    w="${(l:pad_ln::0:)w}"
  }
  # re-insert decimal
  deci_ln=$((${#w}-deci_ln))
  out=""${w::$deci_ln}"."${w:$deci_ln}""
  # handle neg sign
  ((is_neg)) && out="-"$out""
  print -r "$out"
}

## arbitrarily large integer divider
alid() {
  local num1="$1" num2="$2" w out w1 w2 tmp prev_tmp
  local -i neg1 neg2 is_neg cmp
  [[ -z "$num1" || -z "$num2" ]] && return 1
  [[ "$num1" = '-0' ]] && num1=0
  [[ "$num2" = '-0' ]] && num2=0
  # err if divide by zero
  [[ "$num2" = '0' ]] && return 1
  # if num1 is 0, result and remainder will always be 0
  [[ "$num1" = '0' ]] && {
    al_rem=0
    print -r '0'
    return 0
  }
  # handle negs
  [[ ${num1::1} = '-' ]] && {
    num1=${num1:1}
    ((neg1++))
  }
  [[ ${num2::1} = '-' ]] && {
    num2=${num2:1}
    ((neg2++))
  }
  ((neg1!=neg2)) && ((is_neg++))
  # if num1 is less than num2, exit with remainder
  alcm "$num1" "$num2"; cmp=$?
  ((cmp==2)) && {
    al_rem="$num1"
    print -r '0'
    return 0
  }
  cmp=0
  # iterate num1 from l->r
  for ((i=1; i<=${#num1}; i++)); do
    w=""$w""$num1[$i]""
    # strip 0s
    ((${#w}!=1)) && {
      until [[ ${w::1} != '0' ]]; do
        ((${#w}==1)) && break
        w=${w:1}
      done
    }
    # if num2 > w, write 0
    alcm "$w" "$num2"; cmp=$?
    ((cmp==2)) && {
      out+="0"
      continue
    # else do long divide (guessing loop)
    } || {
      tmp="0"
      for ((j=1; j>0; j++)); do
        prev_tmp="$tmp"
        tmp=$(alia "$tmp" "$num2")
        alcm "$tmp" "$w"; cmp=$?
        ((cmp==1)) && {
          ((j--))
          out+="$j"
          break
        }
      done
      w=$(alis "$w" "$prev_tmp")
    }
  done
  # strip 0s from out
  until [[ ${out::1} != '0' ]]; do
    ((${#out}==1)) && break
    out=${out:1}
  done
  # set neg if needed
  ((is_neg)) && out="-"$out""
  # set remainder to al_rem
  al_rem="$w"
  # output result
  print -r "$out"
}

